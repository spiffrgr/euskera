{
  "id": "l02",
  "title": "NON? NORA? NONDIK?",
  "grammar_note": {
    "title": "Las tres preguntas de lugar",
    "body": "El sistema de lugar en euskera tiene tres preguntas distintas:\n**NON?** → ¿Dónde? (posición estática, con EGON)\n**NORA?** → ¿Adónde? (movimiento hacia, con JOAN)\n**NONDIK?** → ¿De dónde? (origen/movimiento desde, con ETORRI)\n\nEjemplos:\n**Non zaude?** → ¿Dónde estás?\n**Nora zoaz?** → ¿Adónde vas?\n**Nondik zatoz?** → ¿De dónde vienes?",
    "tip": "Estas preguntas corresponden exactamente a los casos locativo (-n), alativo (-ra) y ablativo (-tik) que ya conoces."
  },
  "slides": [
    { "eu": "Non zaude?", "es": "¿Dónde estás?", "example_eu": "Non zaude? —Etxean nago.", "example_es": "¿Dónde estás? —Estoy en casa." },
    { "eu": "Nora zoaz?", "es": "¿Adónde vas?", "example_eu": "Nora zoaz? —Eskolara noa.", "example_es": "¿Adónde vas? —Voy a la escuela." },
    { "eu": "Nondik zatoz?", "es": "¿De dónde vienes?", "example_eu": "Nondik zatoz? —Dendatik nator.", "example_es": "¿De dónde vienes? —Vengo de la tienda." },
    { "eu": "Nongoa zara?", "es": "¿De dónde eres?", "example_eu": "Nongoa zara? —Donostia-koa naiz.", "example_es": "¿De dónde eres? —Soy de San Sebastián." }
  ],
  "exercises": [
    { "id": "e01", "type": "multiple_choice", "instruction": "¿Qué pregunta usas para saber adónde va alguien?", "options": ["Non?", "Nondik?", "Nora?", "Noiz?"], "answer": "Nora?" },
