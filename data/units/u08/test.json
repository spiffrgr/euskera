    { "id": "e08", "type": "order_words", "words": ["Egunero", "eskolara", "joaten", "naiz."], "translation": "Todos los días voy a la escuela.", "answer": "Egunero eskolara joaten naiz." },
    { "id": "e09", "type": "translation_eu_es", "eu": "Eskolatik nator.", "answer": "Vengo de la escuela." },
