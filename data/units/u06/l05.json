{
  "id": "l05",
  "title": "Otorduak (Las comidas del día)",
  "grammar_note": {
    "title": "Otordu-aditzak (Verbos de las comidas)",
    "body": "Cada comida tiene su propio verbo: **gosaldu** (desayunar), **bazkaldu** (comer a mediodía), **afaldu** (cenar). Presente habitual: **gosaltzen naiz/dut**, **bazkal­tzen dut**, **afaltzen dut**. La hora + otordua: **goizean gosaltzen dut** (por la mañana desayuno).",
    "tip": "gosaria → gosaldu, bazkaria → bazkaldu, afaria → afaldu"
  },
  "slides": [
    {
      "eu": "gosaria / gosaldu",
      "es": "desayuno / desayunar",
      "example_eu": "Goizean zazpitan gosaltzen dut.",
      "example_es": "Por la mañana desayuno a las siete."
    },
    {
      "eu": "bazkaria / bazkaldu",
      "es": "comida del mediodía / comer",
      "example_eu": "Eguerdian ordu bietan bazkal­tzen dut.",
      "example_es": "Al mediodía como a las dos."
    },
    {
      "eu": "afaria / afaldu",
      "es": "cena / cenar",
      "example_eu": "Gauean bederatzitan afaltzen dugu.",
      "example_es": "Por la noche cenamos a las nueve."
    }
  ],
