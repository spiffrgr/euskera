      "example_eu": "Hodei asko daude zeruan.",
      "example_es": "Hay muchas nubes en el cielo."
    },
    {
      "eu": "lainoa / lainoa dago",
      "es": "la niebla / hay niebla",
      "example_eu": "Lainoa dago eta ezer ez da ikusten.",
      "example_es": "Hay niebla y no se ve nada."
    }
  ],
