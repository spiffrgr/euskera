    "title":  "Zer ordu da? (¿Qué hora es?)",
    "grammar_note":  {
                         "title":  "Orduak (Las horas)",
                         "body":  "Para las horas se usa **ordu + número**: **Ordu bat da** (es la una). Para 2+ se usa la forma plural con artículo: **Ordu biak dira** (son las dos). Para indicar el momento del día: **goizean** (mañana), **arratsaldean** (tarde), **gauean** (noche).",
                         "tip":  "da = es (singular), dira = son (plural) — recuerda cambiar el verbo"
                     },
    "slides":  [
                   {
                       "eu":  "Zer ordu da?",
                       "es":  "¿Qué hora es?",
                       "example_eu":  "Barkatu, zer ordu da mesedez?",
                       "example_es":  "Perdona, ¿qué hora es, por favor?"
                   },
                   {
                       "eu":  "Ordu bat da / Ordu biak dira",
                       "es":  "Es la una / Son las dos",
                       "example_eu":  "Goizeko ordu biak dira.",
                       "example_es":  "Son las dos de la mañana."
                   },
                   {
                       "eu":  "goizean / arratsaldean / gauean",
                       "es":  "de mañana / de tarde / de noche",
                       "example_eu":  "Goizean esnatzen naiz eta gauean lo egiten dut.",
                       "example_es":  "Por la mañana me despierto y por la noche duermo."
                   }
