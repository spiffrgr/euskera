      "answer": "saskibaloia"
    },
    {
      "id": "e02",
      "type": "translation_es_eu",
      "instruction": "Traduce al euskera",
      "es": "Me gusta mucho el fútbol.",
      "answer": "Oso gustuko dut futbola."
    },
    {
      "id": "e03",
      "type": "fill_blank",
      "instruction": "Rellena el hueco",
      "sentence": "Astean behin igerian _ dut.",
      "translation": "Nado una vez a la semana.",
      "hint": "egin → presente habitual",
      "answer": "egiten"
    },
    {
      "id": "e04",
      "type": "match_pairs",
      "instruction": "Empareja la afición con su traducción",
      "pairs": [
        { "eu": "musika entzun", "es": "escuchar música" },
