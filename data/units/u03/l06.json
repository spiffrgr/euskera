{
  "id": "l06",
  "title": "Hizkuntzak (Los idiomas)",
  "grammar_note": {
    "title": "Hizkuntzak: -z atzizkia (El sufijo -z)",
    "body": "Para decir 'en [idioma]' se usa el instrumental **-z**: **euskaraz** (en euskera), **gaztelaniaz** (en español), **frantsesez** (en francés), **ingelesez** (en inglés). El verbo es **hitz egiten dut** (hablo, literalmente 'hago palabras').",
    "tip": "Euskaraz hitz egiten al duzu? = ¿Hablas (en) euskera? — al marca la pregunta sí/no."
  },
  "slides": [
    {
      "eu": "euskaraz / gaztelaniaz",
      "es": "en euskera / en español",
      "example_eu": "Euskaraz eta gaztelaniaz hitz egiten dut.",
      "example_es": "Hablo en euskera y en español."
    },
    {
      "eu": "ingelesez / frantsesez",
      "es": "en inglés / en francés",
      "example_eu": "Ingelesez ondo hitz egiten duzu?",
      "example_es": "¿Hablas bien inglés?"
    },
    {
      "eu": "elebiduna / hizkuntza",
      "es": "bilingüe / idioma",
      "example_eu": "Elebiduna naiz: euskara eta gaztelania.",
      "example_es": "Soy bilingüe: euskera y español."
    }
  ],
  "exercises": [
