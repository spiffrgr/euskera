      "sentence": "Zuk zer gustuko _?",
      "translation": "¿Qué te gusta?",
      "options": ["dut", "duzu", "du", "dute"],
      "answer": "duzu"
    },
    {
      "id": "e07",
      "type": "true_false",
      "instruction": "¿Verdadero o falso?",
