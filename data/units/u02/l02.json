  "objective": "Contar del 11 al 20 en euskera",
  "grammar_note": {
    "title": "Cómo se forman los números del 11 al 19",
    "body": "Del 11 al 19 se forma con **hamaika...** o con **hamar + eta + número**:\n\n11=hamaika / 12=hamabi / 13=hamahiru / 14=hamalau\n15=hamabost / 16=hamasei / 17=hamazazpi / 18=hemezortzi\n19=hemeretzi / 20=hogei",
    "tip": "Nota: '18' y '19' son irregulares: hemezortzi y hemeretzi (no 'hama-')."
  },
  "slides": [
    { "eu": "Hamaika, hamabi, hamahiru", "es": "Once, doce, trece", "example_eu": "Hamabiko taldea dugu.", "example_es": "Tenemos un equipo de doce." },
    { "eu": "Hamalau, hamabost, hamasei", "es": "Catorce, quince, dieciséis", "example_eu": "Hamabost urte ditut.", "example_es": "Tengo quince años." },
    { "eu": "Hamazazpi, hemezortzi, hemeretzi, hogei", "es": "Diecisiete, dieciocho, diecinueve, veinte", "example_eu": "Hogei lagun etorri dira.", "example_es": "Han venido veinte personas." }
  ],
