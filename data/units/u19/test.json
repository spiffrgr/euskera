      "answer": "lagunarekin"
    },
    {
      "id": "e02",
      "type": "translation_es_eu",
      "instruction": "Traduce al euskera",
      "es": "¿Quieres venir conmigo?",
      "answer": "Nirekin etorri nahi duzu?"
    },
    {
