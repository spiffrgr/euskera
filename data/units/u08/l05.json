    },
    {
      "eu": "Etorri zaitez! / Etorri gaitezen!",
      "es": "¡Ven! / ¡Vengamos!",
      "example_eu": "Etorri zaitez hona, mesedez!",
      "example_es": "¡Ven aquí, por favor!"
    }
