{
    "id": "test",
    "title": "Test de la Unidad 11: Galderak",
    "objective": "Demostrar que dominas todas las palabras interrogativas del euskera A1",
    "type": "test",
    "exercises": [
        {
            "id": "e01",
            "type": "multiple_choice",
            "instruction": "¿Qué interrogativa se usa para preguntar por personas?",
            "options": ["Zer?", "Non?", "Nor?", "Noiz?"],
            "answer": "Nor?"
        },
        {
            "id": "e02",
            "type": "translation_eu_es",
            "eu": "Nora zoaz?",
            "answer": "¿Adónde vas?"
        },
        {
            "id": "e03",
            "type": "translation_eu_es",
            "eu": "Nola deitzen zara?",
            "answer": "¿Cómo te llamas?"
        },
        {
            "id": "e05",
            "type": "translation_eu_es",
            "eu": "Nolakoa zara?",
            "answer": "¿Cómo eres?"
        },
        {
            "id": "e06",
            "type": "multiple_choice",
            "instruction": "¿Cómo se forma una pregunta sí/no en euskera?",
            "options": ["Con 'zer'", "Con 'al'", "Con 'non'", "Con 'noiz'"],
            "answer": "Con 'al'"
        },
        {
            "id": "e07",
            "type": "translation_eu_es",
