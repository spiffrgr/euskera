{
    "id": "l07",
    "title": "IZAN errepasaketa (repaso completo)",
    "objective": "Consolidar todo el paradigma de IZAN en presente: afirmación, negación y preguntas",
    "slides": [
        {
            "eu": "Orain: naiz / zara / da / gara / zarete / dira",
            "es": "Presente: soy / eres / es / somos / sois / son",
            "example_eu": "Ni Bilbokoa naiz. Gu euskaldunak gara.",
            "example_es": "Soy de Bilbao. Somos vascos."
        },
        {
            "eu": "Ezezkoa: ez naiz / ez zara / ez da...",
            "es": "Negación: no soy / no eres / no es...",
            "example_eu": "Ez naiz Bilbokoa. Ez gara Madriletarrak.",
            "example_es": "No soy de Bilbao. No somos de Madrid."
        },
        {
            "eu": "Galderak: Nor? Nongoa? Nolakoa?",
            "es": "Preguntas: ¿Quién? ¿De dónde? ¿Cómo es?",
            "example_eu": "Nor zara? Nongoa zara? Nolakoa zara?",
            "example_es": "¿Quién eres? ¿De dónde eres? ¿Cómo eres?"
        }
    ],
    "exercises": [
