{
    "id":  "l07",
    "title":  "Gustukoak (Lo que me gusta)",
    "grammar_note":  {
                         "title":  "Gustatzen zait / zaizkit",
                         "body":  "\u0027Me gusta\u0027 es **gustatzen zait** (para una cosa) y **gustatzen zaizkit** (para varias cosas). Lo que gusta funciona como sujeto: **Musika gustatzen zait** (La música me gusta). Para preguntar: **Zer gustatzen zaizu?** (¿Qué te gusta?)",
                         "tip":  "zait = me (gusta una cosa) / zaizkit = me (gustan varias cosas)"
                     },
    "slides":  [
                   {
                       "eu":  "Gustatzen zait (singular)",
                       "es":  "Me gusta",
                       "example_eu":  "Musika gustatzen zait.",
                       "example_es":  "Me gusta la música."
                   },
                   {
                       "eu":  "Gustatzen zaizkit (plural)",
                       "es":  "Me gustan",
                       "example_eu":  "Liburuak gustatzen zaizkit.",
                       "example_es":  "Me gustan los libros."
                   },
                   {
                       "eu":  "kirola / musika / janaria / irakurtzea",
                       "es":  "deporte / música / comida / leer",
                       "example_eu":  "Kirola eta irakurtzea gustatzen zaizkit.",
                       "example_es":  "Me gustan el deporte y leer."
                   }
               ],
