{
  "id": "l04",
  "unit": "u15",
  "title": "Liburuak eta irakurketa (Libros y lectura)",
  "slides": [
    {
      "eu": "Liburua — el libro / Liburuak — los libros",
      "es": "Liburua = libro + artículo -a. Liburuak = libros (plural con -ak). Irakurketa = la lectura.",
      "example_eu": "Liburuak irakurtzen ditut.",
      "example_es": "Leo libros. (plural → ditut)"
    },
    {
      "eu": "Eleberria — la novela / Ipuin-bilduma — cuentos",
      "es": "Eleberri + -a = novela. Ipuin = cuento, bilduma = colección. Ipuin-bilduma = libro de cuentos.",
      "example_eu": "Eleberriak irakurtzen ditut.",
      "example_es": "Leo novelas."
    },
    {
      "eu": "Poesia — la poesía / Historia-liburuak — libros de historia",
      "es": "Poesia: préstamo directo. Historia-liburuak: historia + liburuak (compuesto).",
      "example_eu": "Poesia gustuko dut.",
      "example_es": "Me gusta la poesía."
    },
    {
      "eu": "Komikia — el cómic",
      "es": "Komiki + -a = el cómic. Muy popular entre jóvenes. También manga en contexto moderno.",
      "example_eu": "Haurtzaroan komikiak irakurtzen nituen.",
      "example_es": "De niño leía cómics."
    },
    {
      "eu": "Liburutegia — la biblioteca / Liburudenda — la librería",
      "es": "Liburutegi + -a = biblioteca. Liburudenda: liburu + denda (tienda) = librería.",
      "example_eu": "Liburutegian irakurtzen dut.",
      "example_es": "Leo en la biblioteca."
    },
    {
      "eu": "Astean behin / Batzuetan / Inoiz ez — frecuencia",
      "es": "Astean behin = una vez a la semana. Batzuetan = a veces. Inoiz ez = nunca. Askotan = a menudo.",
      "example_eu": "Inoiz ez dut komikirik irakurtzen.",
      "example_es": "No leo cómics nunca."
    }
  ],
