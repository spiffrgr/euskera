{
  "id": "l04",
  "title": "Familia (La familia)",
  "grammar_note": {
    "title": "Izenordain posesiboak (Posesivos)",
    "body": "Los posesivos van **delante** del sustantivo: **nire** aita (mi padre), **zure** ama (tu madre), **bere** anaia (su hermano). Para decir quién es: **Nire aita medikua da** (Mi padre es médico).",
    "tip": "nire = mi, zure = tu, bere = su. Siempre delante del nombre."
  },
  "slides": [
    {
      "eu": "aita / ama",
      "es": "padre / madre",
      "example_eu": "Nire aita irakaslea da.",
      "example_es": "Mi padre es profesor."
    },
    {
      "eu": "anaia / ahizpa",
      "es": "hermano / hermana",
      "example_eu": "Nire anaia Bilbon bizi da.",
      "example_es": "Mi hermano vive en Bilbao."
    },
    {
      "eu": "seme / alaba",
      "es": "hijo / hija",
      "example_eu": "Bi seme-alaba ditut.",
      "example_es": "Tengo dos hijos."
