{
    "id":  "l03",
    "title":  "NINTZEN, ZINEN, ZEN (pasado)",
    "grammar_note":  {
                         "title":  "IZAN – iragana (IZAN – pasado)",
                         "body":  "Pasado de IZAN: **ni nintzen** (yo era/estaba), **zu zinen** (tú eras/estabas), **bera zen** (él/ella era/estaba), **gu ginen** (nosotros éramos), **haiek ziren** (ellos eran). Expresa estados pasados: **Gaztea nintzen** (Era joven).",
                         "tip":  "zen / ziren son las formas más usadas: Bera medikua zen (Era médico). Gazteak ziren (Eran jóvenes)."
                     },
    "slides":  [
                   {
                       "eu":  "ni nintzen / zu zinen / bera zen",
                       "es":  "yo era/estaba / tú eras / él-ella era",
                       "example_eu":  "Ni gaztea nintzen. Zu nolakoa zinen?",
                       "example_es":  "Yo era joven. ¿Cómo eras tú?"
                   },
                   {
                       "eu":  "gu ginen / haiek ziren",
                       "es":  "nosotros éramos / ellos/ellas eran",
                       "example_eu":  "Gu ikasle ginen eta haiek irakasle ziren.",
                       "example_es":  "Nosotros éramos estudiantes y ellos eran profesores."
                   },
                   {
                       "eu":  "Gaztea nintzen eta alaia.",
                       "es":  "Era joven y alegre.",
                       "example_eu":  "Hamar urte nituenean, alaia eta ausarta nintzen.",
                       "example_es":  "Cuando tenía diez años, era alegre y valiente."
                   }
               ],
