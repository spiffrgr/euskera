  "title": "Nire zaletasunak (Mis aficiones)",
  "slides": [
    {
      "eu": "Zaletasuna — la afición",
      "es": "Una 'zaletasun' es algo que te gusta hacer habitualmente, tu afición.",
      "example_eu": "Zer da zure zaletasuna?",
      "example_es": "¿Cuál es tu afición?"
    },
    {
      "eu": "Musika entzun — escuchar música",
      "es": "Para hablar de actividades habituales usamos el presente habitual: entzuten dut.",
      "example_eu": "Egunero musika entzuten dut.",
      "example_es": "Escucho música cada día."
    },
    {
      "eu": "Telebista ikusi — ver la televisión",
      "es": "Ikusi significa 'ver'. Con el presente habitual: ikusten dut.",
      "example_eu": "Gauean telebista ikusten dut.",
      "example_es": "Por la noche veo la televisión."
    },
    {
      "eu": "Irakurri — leer",
      "es": "Irakurri es el infinitivo. Habitual: irakurtzen dut (leo) / irakurtzen ditut (leo [varios libros]).",
      "example_eu": "Astean behin liburuak irakurtzen ditut.",
      "example_es": "Leo libros una vez a la semana."
    },
    {
      "eu": "Bidaiatu — viajar / Sukaldatu — cocinar",
      "es": "Muchas aficiones acaban en -tu/-du en infinitivo. Habitual: bidaiatzen dut, sukaldetzen dut.",
      "example_eu": "Oso gustuko dut bidaiatzea.",
      "example_es": "Me gusta mucho viajar."
    },
    {
      "eu": "Lagunekin egon — estar con amigos / Argazkiak atera — hacer fotos",
      "es": "Egon = estar. Atera = sacar/hacer (fotos). Argazkiak = fotos (plural).",
      "example_eu": "Asteburuan lagunekin egoten naiz.",
      "example_es": "Los fines de semana estoy con mis amigos."
    }
  ],
