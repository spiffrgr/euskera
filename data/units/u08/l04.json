    "title":  "Nora zoaz? (JOAN + nora?)",
    "grammar_note":  {
                         "title":  "Norabidea: -ra/-era atzizkia (El alativo -ra)",
                         "body":  "Para decir \u0027hacia dónde\u0027 (adónde), el euskera añade **-ra** (tras vocal) o **-era** (tras consonante): **etxera** = a casa (etxe + ra), **mendira** = a la montaña (mendi + ra), **Bilbora** = a Bilbao (Bilbo + ra). La pregunta es **nora?** (¿adónde?).",
                         "tip":  "non? (¿dónde?) → respuesta con -n/-an. nora? (¿adónde?) → respuesta con -ra/-era."
                     },
    "slides":  [
                   {
                       "eu":  "Nora zoaz? / nora joaten zara?",
                       "es":  "¿Adónde vas?",
                       "example_eu":  "Nora zoaz gaur? — Dendara noa.",
                       "example_es":  "¿Adónde vas hoy? — Voy a la tienda."
                   },
                   {
                       "eu":  "etxera / eskolara / dendara",
                       "es":  "a casa / a la escuela / a la tienda",
                       "example_eu":  "Arratsaldean etxera joaten naiz.",
                       "example_es":  "Por la tarde voy a casa."
                   },
                   {
