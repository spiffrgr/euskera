    "title":  "Ez naiz... (negación con IZAN)",
    "grammar_note":  {
                         "title":  "IZAN – ezezkoa (IZAN – negación)",
                         "body":  "Para negar con IZAN, coloca **ez** antes del verbo: **Ez naiz** (no soy), **ez zara** (no eres), **ez da** (no es), **ez gara** (no somos), **ez dira** (no son). En pasado: **ez nintzen** (no era), **ez zen** (no era - él/ella).",
                         "tip":  "Ez siempre va antes del verbo: Ez naiz medikua (No soy médico). Ez da Bilbokoa (No es de Bilbao)."
                     },
    "slides":  [
                   {
                       "eu":  "Ez naiz / Ez zara / Ez da",
                       "es":  "No soy / No eres / No es",
                       "example_eu":  "Ez naiz medikua, irakaslea naiz.",
                       "example_es":  "No soy médico, soy profesor/a."
                   },
                   {
                       "eu":  "Ez gara / Ez dira",
                       "es":  "No somos / No son",
                       "example_eu":  "Ez gara Bilbotarrak, Donostiakoak gara.",
                       "example_es":  "No somos bilbaínos, somos de San Sebastián."
                   },
                   {
                       "eu":  "Ez nintzen / Ez zen",
                       "es":  "No era (yo) / No era (él/ella)",
                       "example_eu":  "Ez nintzen alaia, triste nintzen.",
                       "example_es":  "No era alegre, era triste."
                   }
               ],
