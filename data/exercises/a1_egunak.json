[
  { "id": "egu_001", "eu": "Astelehena", "es": "Lunes", "example_eu": "Astelehena lan-eguna da.", "example_es": "El lunes es día de trabajo." },
  { "id": "egu_002", "eu": "Asteartea", "es": "Martes", "example_eu": "Asteartean pilota partida dago.", "example_es": "El martes hay partido de pelota." },
  { "id": "egu_003", "eu": "Asteazkena", "es": "Miércoles", "example_eu": "Asteazkenean arraina jaten dugu.", "example_es": "El miércoles comemos pescado." },
  { "id": "egu_004", "eu": "Osteguna", "es": "Jueves", "example_eu": "Ostegunak asteko laugarren eguna dira.", "example_es": "El jueves es el cuarto día de la semana." },
  { "id": "egu_005", "eu": "Ostirala", "es": "Viernes", "example_eu": "Ostirala nire egun gustukoa da.", "example_es": "El viernes es mi día favorito." },
  { "id": "egu_006", "eu": "Larunbata", "es": "Sábado", "example_eu": "Larunbatetan paseatzera joaten naiz.", "example_es": "Los sábados voy a pasear." },
  { "id": "egu_007", "eu": "Igandea", "es": "Domingo", "example_eu": "Igandea familia-eguna da.", "example_es": "El domingo es el día de familia." },
  { "id": "egu_008", "eu": "Gaur", "es": "Hoy", "example_eu": "Gaur oso eguraldi ona dago.", "example_es": "Hoy hace muy buen tiempo." },
  { "id": "egu_009", "eu": "Bihar", "es": "Mañana (el día siguiente)", "example_eu": "Bihar etortzen naiz.", "example_es": "Mañana vengo." },
  { "id": "egu_010", "eu": "Atzo", "es": "Ayer", "example_eu": "Atzo zinera joan nintzen.", "example_es": "Ayer fui al cine." },
  { "id": "egu_011", "eu": "Astea", "es": "Semana", "example_eu": "Astea zazpi egunek osatzen dute.", "example_es": "La semana la forman siete días." },
  { "id": "egu_012", "eu": "Hilabetea", "es": "Mes", "example_eu": "Hilabete honetan bilerak daude.", "example_es": "Este mes hay reuniones." },
  { "id": "egu_013", "eu": "Urtea", "es": "Año", "example_eu": "Urte berri on!", "example_es": "¡Feliz año nuevo!" },
  { "id": "egu_014", "eu": "Zer egun da gaur?", "es": "¿Qué día es hoy?", "example_eu": "Zer egun da gaur? Astelehena da.", "example_es": "¿Qué día es hoy? Es lunes." },
  { "id": "egu_015", "eu": "Zer ordu da?", "es": "¿Qué hora es?", "example_eu": "Zer ordu da? Ordu bata da.", "example_es": "¿Qué hora es? Es la una." },
  { "id": "egu_016", "eu": "Ordu bata da", "es": "Es la una", "example_eu": "Ordu bata da, bazkalduko dugu.", "example_es": "Es la una, vamos a comer." },
  { "id": "egu_017", "eu": "Biak dira", "es": "Son las dos", "example_eu": "Biak dira eta oraindik hemen nago.", "example_es": "Son las dos y todavía estoy aquí." },
  { "id": "egu_018", "eu": "Laurden gutxi", "es": "Menos cuarto", "example_eu": "Seiak eta laurden gutxi dira.", "example_es": "Son las seis menos cuarto." },
  { "id": "egu_019", "eu": "Laurden", "es": "Y cuarto", "example_eu": "Hamaikak eta laurden dira.", "example_es": "Son las once y cuarto." },
  { "id": "egu_020", "eu": "Erdia", "es": "Y media", "example_eu": "Bostak eta erdia dira.", "example_es": "Son las cinco y media." },
  { "id": "egu_021", "eu": "Goiza", "es": "Mañana (parte del día)", "example_eu": "Goizean eskolara joaten naiz.", "example_es": "Por la mañana voy a la escuela." },
  { "id": "egu_022", "eu": "Eguerdian", "es": "Al mediodía", "example_eu": "Eguerdian etxera itzultzen naiz.", "example_es": "Al mediodía vuelvo a casa." },
  { "id": "egu_023", "eu": "Arratsaldea", "es": "Tarde (parte del día)", "example_eu": "Arratsaldean lana bukatzen dut.", "example_es": "Por la tarde termino el trabajo." },
  { "id": "egu_024", "eu": "Gaua", "es": "Noche", "example_eu": "Gauean lo egiten dut.", "example_es": "Por la noche duermo." },
  { "id": "egu_025", "eu": "Goizetan", "es": "Por las mañanas", "example_eu": "Goizetan kafea hartzen dut.", "example_es": "Por las mañanas tomo café." },
  { "id": "egu_026", "eu": "Arratsaldetan", "es": "Por las tardes", "example_eu": "Arratsaldetan paseatu ohi dut.", "example_es": "Por las tardes suelo pasear." },
  { "id": "egu_027", "eu": "Orain", "es": "Ahora", "example_eu": "Orain zer egiten ari zara?", "example_es": "¿Qué estás haciendo ahora?" },
  { "id": "egu_028", "eu": "Gero", "es": "Después / Luego", "example_eu": "Gero ikusiko dugu.", "example_es": "Luego lo veremos." },
  { "id": "egu_029", "eu": "Lehen", "es": "Antes", "example_eu": "Lehen hemen bizi nintzen.", "example_es": "Antes vivía aquí." },
  { "id": "egu_030", "eu": "Beti", "es": "Siempre", "example_eu": "Beti goiz jaiki ohi naiz.", "example_es": "Siempre me levanto temprano." },
  { "id": "egu_031", "eu": "Inoiz ez", "es": "Nunca", "example_eu": "Inoiz ez dut berandu jaikitzen.", "example_es": "Nunca me levanto tarde." }
