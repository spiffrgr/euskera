            "type": "translation_es_eu",
            "es": "¿Cómo estás?",
            "answer": "Nola zaude?"
        },
        {
            "id": "e09",
            "type": "order_words",
            "words": ["Nola", "esaten", "da", "euskaraz", "'kaixo'?"],
            "translation": "¿Cómo se dice 'kaixo' en euskera?",
            "answer": "Nola esaten da euskaraz 'kaixo'?"
        },
        {
            "id": "e10",
            "type": "match_pairs",
            "pairs": [
                { "eu": "Nor?", "es": "¿Quién?" },
                { "eu": "Non?", "es": "¿Dónde?" },
                { "eu": "Noiz?", "es": "¿Cuándo?" },
                { "eu": "Nola?", "es": "¿Cómo?" }
            ]
        },
        {
            "id": "e11",
            "type": "grammar_select",
            "sentence": "___ zaude? —Etxean nago.",
            "translation": "¿Dónde estás? —Estoy en casa.",
            "options": ["Non", "Nora", "Nondik", "Noiz"],
            "answer": "Non"
        },
        {
            "id": "ow01",
