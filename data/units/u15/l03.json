  "title": "Musika eta zinema (Música y cine)",
  "slides": [
    {
      "eu": "Musika motak — los géneros musicales",
      "es": "En euskera los géneros musicales suelen ser préstamos con el artículo -a añadido.",
      "example_eu": "Zer musika mota gustatzen zaizu?",
      "example_es": "¿Qué tipo de música te gusta?"
    },
    {
      "eu": "Pop musika — música pop / Rocka — el rock",
      "es": "Pop musika: dos palabras. Rock + a → rocka. Musika entzun = escuchar música (actividad).",
      "example_eu": "Nik pop musika gustuko dut.",
      "example_es": "A mí me gusta la música pop."
    },
    {
      "eu": "Jazza — el jazz / Musika klasikoa — música clásica",
      "es": "Jazza: préstamo + artículo. Musika klasikoa: adjetivo klasiko + -a. Klasikoa = clásica.",
      "example_eu": "Amak musika klasikoa gustuko du.",
      "example_es": "A mi madre le gusta la música clásica."
    },
    {
      "eu": "Zineman joan — ir al cine / Antzerkia ikusi — ver teatro",
      "es": "Zinema = el cine (lugar). Zineman = en el cine / al cine (locativo). Antzerkia = el teatro.",
      "example_eu": "Ostiralean zineman joaten gara.",
      "example_es": "Los viernes vamos al cine."
    },
    {
      "eu": "Dantzan egin / Dantzatu — bailar",
      "es": "Dantzan egin (lit. 'hacer en danza') o simplemente dantzatu. Dantza = el baile/danza.",
      "example_eu": "Larunbatean dantzan egiten dut.",
      "example_es": "Los sábados bailo."
    },
    {
      "eu": "Abestu — cantar / Jolastu — jugar",
      "es": "Abestu = cantar. Jolastu = jugar (también con juegos, videojuegos). Ambos en presente habitual.",
      "example_eu": "Batzuetan abestu egiten dut.",
      "example_es": "A veces canto."
    }
  ],
